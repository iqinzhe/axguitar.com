{
  "name": "JF! Gadai | Sistem Pencatatan Gadai",
  "short_name": "JF! Gadai",
  "description": "Sistem manajemen pinjaman gadai untuk admin dan manajer toko.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#3b82f6",
  "orientation": "portrait",
  "lang": "id",
  "dir": "ltr",
  "categories": ["finance", "business"],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "icons": [
